{
  "name": "tokenmaxxing",
  "version": "0.1.0",
  "description": "TokenMaxxing — GitHub Contributions + Spotify Wrapped for AI developers. A premium local-first desktop app that analyzes your AI coding tool usage.",
  "author": "Launchcraft Studio <hello@acmediamarketing.com>",
  "license": "MIT",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/patch-dev-name.mjs",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "rebuild": "electron-builder install-app-deps",
    "icons": "node scripts/gen-icons.mjs",
    "smoke": "esbuild scripts/smoke.ts --bundle --platform=node --format=cjs --alias:@shared=./src/shared --alias:@main=./src/main --external:electron --external:better-sqlite3 --outfile=.smoke.cjs && node .smoke.cjs && rm -f .smoke.cjs",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "postinstall": "node scripts/rebuild-native.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "sql.js": "^1.12.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.20.1",
    "framer-motion": "^12.4.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.475.0",
    "postcss": "^8.5.2",
    "prettier": "^3.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.29.0",
    "recharts": "^2.15.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  }
}
