# ─────────────────────────────────────────────────────────────
# TokenMaxxing — Desktop app environment
# Copy to `.env` for local development. The app works fully offline;
# the only cloud config it needs is the URL of the backend API.
#
# NOTE: The app talks ONLY to the backend. Supabase + OAuth client
# IDs/secrets live in the backend (see ../backend/.env.example) — the
# desktop app never holds them.
# ─────────────────────────────────────────────────────────────

# Base URL of the TokenMaxxing backend API (enables rankings, leaderboard,
# globe, and OAuth sign-in). Leave unset to run fully offline (local estimates).
VITE_API_BASE_URL=http://localhost:8787

# Custom protocol used for OAuth deep-link redirects back into the app
VITE_APP_PROTOCOL=tokenmaxxing
