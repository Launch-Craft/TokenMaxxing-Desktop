# Local release credentials — used by `npm run release:local`.
#
# Copy this file to `.env.release` (which is gitignored) and fill in the values.
#   cp .env.release.example .env.release
#
# These are the SAME values you stored as GitHub Actions secrets.

# Apple ID email used for notarization.
APPLE_ID="you@example.com"

# App-specific password (NOT your Apple ID password). Create one at:
#   https://appleid.apple.com  →  Sign-In and Security  →  App-Specific Passwords
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Your Apple Developer Team ID — taken from your Developer ID cert.
APPLE_TEAM_ID="644SJWH566"

# GitHub token used to publish the release. EASIEST: leave this blank and just
# run `gh auth login` once — the release script borrows a token from the gh CLI
# automatically. (Alternatively paste a token from https://github.com/settings/tokens
# with `contents: write` on Launch-Craft/TokenMaxxing-Desktop.)
# If there's no token at all, the build still signs + notarizes locally; you then
# upload dist/TokenMaxxing.dmg to a GitHub release by hand.
GH_TOKEN=""


